# Google Apps Script Web App URL. Example: https://script.google.com/macros/s/AKfycb.../exec
WEBAPP_URL=

# true = browser hidden, false = see the browser while testing
HEADLESS=false

# Optional delay per Playwright action in milliseconds, useful for watching the first test
SLOWMO_MS=150

# Limit to one store name for testing. Leave empty for all Active stores.
ONLY_STORE=
